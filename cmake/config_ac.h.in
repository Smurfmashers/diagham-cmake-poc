/*
 * config.h: generated by CMake for DiagHam (modernisation PoC)
 *
 * In the autotools build, src/config.h (in source tree) #includes
 * "config_ac.h" (generated by autoconf in the build tree).
 * In the CMake build, we generate a single combined file in the
 * build tree that supersedes both.
 *
 * This is a faithful translation of the autotools-defined HAVE_* flags
 * to the equivalent CMake-controlled options.
 */

#ifndef DIAGHAM_CMAKE_CONFIG_AC_H
#define DIAGHAM_CMAKE_CONFIG_AC_H

/* Endianness, set by CMake's test_big_endian() */
#cmakedefine IS_BIG_ENDIAN
#ifdef IS_BIG_ENDIAN
#define HAVE_BIGENDIAN
#else
#define HAVE_LITTLEENDIAN
#endif

/* Standard headers, modern systems all have these */
#define HAVE_INTTYPES_H 1
#define HAVE_STDINT_H 1
#define HAVE_STDLIB_H 1
#define HAVE_STRING_H 1
#define HAVE_SYS_STAT_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_UNISTD_H 1
#define HAVE_SYS_TIME_H 1
#define STDC_HEADERS 1

/* erfc() is in standard <cmath> on every modern target */
#define HAVE_ERFC 1

/* Module-availability macros, set when the corresponding modules are
 * built. Required by FQHE/src headers that expose FTI-aware constructors
 * inside `#ifdef HAVE_FTI` blocks (e.g. the tightBindingModel overloads
 * of FermionOnSquareLatticeWithSpinMomentumSpaceTruncated). The autotools
 * build sets these via --enable-fqhe / --enable-fti in configure.in. */
#cmakedefine HAVE_FQHE
#cmakedefine HAVE_FTI

/* Optional features, kept commented out in the PoC; a production
 * migration adds find_package() blocks for each and toggles these. */
/* #undef HAVE_BZ2 */
/* #undef HAVE_FFTW */
/* #undef HAVE_GMP */
/* #undef HAVE_GSL */
/* #undef HAVE_LAPACK */
/* #undef HAVE_LAPACK_ONLY */
/* #undef HAVE_MPACK */
/* #undef HAVE_MPI */
/* #undef HAVE_SCALAPACK */
/* #undef HAVE_INTELMKL */
/* #undef HAVE_FORTRAN2C */

/* Package identity */
#define PACKAGE "diagham"
#define PACKAGE_NAME "DiagHam"
#define PACKAGE_VERSION "@PROJECT_VERSION@"
#define PACKAGE_STRING "DiagHam @PROJECT_VERSION@"
#define PACKAGE_BUGREPORT ""
#define PACKAGE_TARNAME "diagham"
#define PACKAGE_URL ""
#define VERSION "@PROJECT_VERSION@"

#endif  /* DIAGHAM_CMAKE_CONFIG_AC_H */
